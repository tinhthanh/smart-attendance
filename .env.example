# Smart Attendance — env template
# Copy to `.env` for local dev. NEVER commit `.env`.
# Generate JWT secrets: openssl rand -hex 32
#
# Two run modes share this file:
#   1) `pnpm nx serve api`        -> api connects via DATABASE_URL/REDIS_URL below (localhost)
#   2) `docker compose up -d`     -> compose OVERRIDES DATABASE_URL/REDIS_URL to point at
#                                     the `postgres` and `redis` service names internally.
#                                     Only POSTGRES_* and JWT_* are read from .env.

# ============ Postgres ============
POSTGRES_DB=smart_attendance
POSTGRES_USER=sa_app
POSTGRES_PASSWORD=change_me_local_dev
POSTGRES_PORT=5432
# Used by `pnpm nx serve api` only — compose overrides this with postgres:5432
DATABASE_URL=postgresql://sa_app:change_me_local_dev@localhost:5432/smart_attendance?schema=public

# ============ Redis ============
REDIS_PORT=6379
# Used by `pnpm nx serve api` only — compose overrides this with redis:6379
REDIS_URL=redis://localhost:6379/0

# ============ API ============
API_PORT=3000
NODE_ENV=development

# ============ JWT (REQUIRED — also used by docker compose) ============
JWT_ACCESS_SECRET=replace_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=replace_with_openssl_rand_hex_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ============ Frontend dev ports ============
PORTAL_PORT=4200
MOBILE_PORT=8100
